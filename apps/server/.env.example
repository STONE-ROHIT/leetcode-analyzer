# Neon Postgres connection string (free tier is sufficient)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

PORT=4000

# console.groq.com -> API Keys. Free tier, no card required.
GROQ_API_KEY=

# Your self-hosted Judge0 instance (see /judge0 folder for deployment).
# Do NOT point this at the public RapidAPI free tier in production use -
# its free quota (~50 req/day) will not cover real traffic.
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# Comma-separated. Leave blank to allow all origins (fine for local dev only).
CLIENT_ORIGIN=http://localhost:5173
